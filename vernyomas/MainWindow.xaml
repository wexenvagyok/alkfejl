<Window x:Class="vernyomas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:vernyomas"
        mc:Ignorable="d"
        Title="Vérnyomás App" Height="450" Width="800">
    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="145" Stroke="Black" VerticalAlignment="Top" Width="369" Fill="#FF4E4E4E"/>
        <DataGrid d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,150,431,48"/>
        <Button Content="Beküldés" HorizontalAlignment="Left" Margin="54,73,0,0" VerticalAlignment="Top" Background="#FF1F2CF7" BorderBrush="{x:Null}" Foreground="White" FontFamily="Arial Rounded MT Bold"/>
        <TextBox x:Name="szisztoles" HorizontalAlignment="Left" Margin="73,6,0,0" TextWrapping="Wrap" Text="000" VerticalAlignment="Top" Width="47" BorderBrush="{x:Null}" Height="12" HorizontalContentAlignment="Center" FontSize="8"/>
        <Label Content="Szisztolés" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontFamily="Arial Rounded MT Bold"/>
        <Label Content="Diasztolés" HorizontalAlignment="Left" Margin="6,12,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontFamily="Arial Rounded MT Bold"/>
        <TextBox x:Name="diasztoles" HorizontalAlignment="Left" Margin="73,18,0,0" TextWrapping="Wrap" Text="00" VerticalAlignment="Top" Width="47" BorderBrush="{x:Null}" Height="12" HorizontalContentAlignment="Center" FontSize="8"/>
        <Label Content="Pulzus" HorizontalAlignment="Left" Margin="28,24,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontFamily="Arial Rounded MT Bold"/>
        <TextBox x:Name="pulzus" HorizontalAlignment="Left" Margin="73,30,0,0" TextWrapping="Wrap" Text="00" VerticalAlignment="Top" Width="47" BorderBrush="{x:Null}" Height="12" HorizontalContentAlignment="Center" FontSize="8"/>
        <Label Content="Napszak" HorizontalAlignment="Left" Margin="17,49,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontFamily="Arial Rounded MT Bold"/>
        <ComboBox x:Name="napszak" HorizontalAlignment="Left" Margin="74,56,0,0" VerticalAlignment="Top" Width="46" Height="12" FontSize="7" BorderBrush="{x:Null}">
            <ComboBoxItem Content="Reggel"/>
            <ComboBoxItem Content="Délben"/>
            <ComboBoxItem Content="Este"/>
        </ComboBox>
        <Label Content="Nap száma" HorizontalAlignment="Left" Margin="3,34,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontFamily="Arial Rounded MT Bold"/>
        <TextBox x:Name="napszam" HorizontalAlignment="Left" Margin="73,42,0,0" TextWrapping="Wrap" Text="00" VerticalAlignment="Top" Width="47" BorderBrush="{x:Null}" Height="12" HorizontalContentAlignment="Center" FontSize="8"/>

    </Grid>
</Window>
